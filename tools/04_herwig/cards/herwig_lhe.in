read snippets/PPCollider.in

set /Herwig/Generators/EventGenerator:EventHandler:LuminosityFunction:Energy 240*GeV

set /Herwig/EventHandlers/LHEReader:FileName @LHE_FILE@
set /Herwig/EventHandlers/LHEReader:WeightWarnings false

set /Herwig/Generators/EventGenerator:EventHandler /Herwig/EventHandlers/LHEReader

set /Herwig/Generators/EventGenerator:NumberOfEvents 10000

saverun @OUT_FILE@ /Herwig/Generators/EventGenerator
